{
  "name": "chex-public-pages",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=payload.config.ts payload",
    "payload:generate:types": "yarn payload generate:types",
    "payload:generate:importmap": "yarn payload generate:importmap",
    "payload:migrate": "yarn payload migrate",
    "payload:migrate:create": "yarn payload migrate:create",
    "payload:migrate:status": "yarn payload migrate:status",
    "payload:migrate:refresh": "yarn payload migrate:refresh",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "next": "16.2.4",
    "payload": "3.83.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sass": "1.93.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.16",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "autoprefixer": "10.4.21",
    "cross-env": "10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "8.5.6",
    "tailwindcss": "4.1.16",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.0"
  }
}
