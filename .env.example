NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_SECRET=replace-with-a-long-random-secret

POSTGRES_DB=payload_app
POSTGRES_USER=payload
POSTGRES_PASSWORD=payload
POSTGRES_PORT=5433

# Optional app database URL. If omitted, local dev falls back to the host-mapped
# local database and Docker falls back to the postgres service.
# DATABASE_URL=postgresql://payload:payload@localhost:5433/payload_app

# Migration source used by yarn db:migrate:local-to-env. If omitted, it defaults
# to postgresql://payload:payload@localhost:5433/payload_app.
# SOURCE_DATABASE_URL=postgresql://payload:payload@localhost:5433/payload_app

# Optional port to expose the app on when running via Docker (default: 3000).
APP_PORT=3000

S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
# Optional: use this when serving media through CloudFront or another public CDN.
# S3_PUBLIC_URL=https://cdn.example.com
